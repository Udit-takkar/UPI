{
  "name": "@repo/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./db": { "import": "./src/db/index.ts", "types": "./src/db/index.ts" },
    "./db/schema": { "import": "./src/db/schema.ts", "types": "./src/db/schema.ts" },
    "./db/types": { "import": "./src/db/types.ts", "types": "./src/db/types.ts" },
    "./schemas": { "import": "./src/schemas/index.ts", "types": "./src/schemas/index.ts" },
    "./redis": { "import": "./src/redis/index.ts", "types": "./src/redis/index.ts" },
    "./kafka": { "import": "./src/kafka/index.ts", "types": "./src/kafka/index.ts" },
    "./logger": { "import": "./src/logger/index.ts", "types": "./src/logger/index.ts" },
    "./crypto": { "import": "./src/crypto/index.ts", "types": "./src/crypto/index.ts" },
    "./state-machine": { "import": "./src/state-machine/index.ts", "types": "./src/state-machine/index.ts" },
    "./response-codes": { "import": "./src/response-codes/index.ts", "types": "./src/response-codes/index.ts" }
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.10.0",
    "kafkajs": "^2.2.4",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "uuidv7": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.31.9",
    "typescript": "5.9.2"
  }
}
